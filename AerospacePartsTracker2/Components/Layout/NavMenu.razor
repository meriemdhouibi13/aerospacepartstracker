@implements IDisposable
@inject NavigationManager NavigationManager

<nav class="apm-nav">
    <div class="apm-nav-brand">
        <svg width="22" height="22" viewBox="0 0 28 28" fill="none">
            <polygon points="14,2 26,22 2,22" stroke="#00d4b8" stroke-width="2" fill="none" />
            <circle cx="14" cy="14" r="3" fill="#00d4b8" />
        </svg>
        <span class="apm-nav-brand-text">Aero<span class="apm-nav-accent">Parts</span></span>
    </div>

    <div class="apm-nav-section-label">Navigation</div>

    <ul class="apm-nav-list">
        <li>
            <NavLink class="apm-nav-link" href="" Match="NavLinkMatch.All">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
                    <polyline points="9 22 9 12 15 12 15 22" />
                </svg>
                Home
            </NavLink>
        </li>
        <li>
            <NavLink class="apm-nav-link" href="parts-manufacturing">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <polygon points="12 2 22 20 2 20" />
                </svg>
                Parts Mfg
            </NavLink>
        </li>
    </ul>


</nav>

@code {
    protected override void OnInitialized()
    {
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
